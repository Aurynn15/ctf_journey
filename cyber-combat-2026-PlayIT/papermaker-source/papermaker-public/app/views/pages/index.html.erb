<% end %>

<section class="landing-section hero">
  <div class="landing-hero">
    <h1>Paper Maker</h1>
    <p>Convert your documents into beautiful PDFs instantly. <br>
    Secure, fast, and completely free.</p>
    <%= link_to "Get Started", render_path, class: "btn-primary" %>
  </div>
</section>

