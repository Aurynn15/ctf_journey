<% content_for :title, "register" %>
<% content_for :stylesheets do %>
  <%= stylesheet_link_tag "auth" %>
<% end %>

<section class="panel auth-panel">
  <h1>Register</h1>

  <%= form_with model: @user, url: register_path, class: "form" do |form| %>
    <label>
      Username
      <%= form.text_field :username, required: true, autofocus: true %>
    </label>

    <label>
      Password
      <%= form.password_field :password, required: true, minlength: 6 %>
    </label>

    <%= form.submit "Create account" %>
  <% end %>
</section>
