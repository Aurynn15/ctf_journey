<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? "Paper Maker - #{yield(:title)}" : "Paper Maker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "main" %>
    <%= yield :stylesheets %>
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="<%= root_path %>">Paper Maker</a>
      <nav>
        <% if logged_in? %>
          <div class="nav-links">
            <% if current_user.role == "admin" %>
              <%= link_to "log", log_path, class: "nav-link" %>
              <%= link_to "config", config_index_path, class: "nav-link" %>
            <% else %>
              <%= link_to "render", render_path, class: "nav-link" %>
              <%= link_to "history", history_path, class: "nav-link" %>
            <% end %>
          </div>
          <div class="account-box">
            <% if current_user.role == "admin" %>
              <span class="account-name" style="color: red; font-weight: bold;"><%= current_user.username %></span>
            <% else %>
              <span class="account-name"><%= current_user.username %></span>
            <% end %>
            <%= button_to "Logout", logout_path, method: :delete, class: "account-logout" %>
          </div>
        <% else %>
          <%= link_to "Login", login_path, class: "link-button" %>
          <%= link_to "Register", register_path, class: "btn-primary", style: "min-height: auto; padding: 8px 16px; font-size: 14px;" %>
        <% end %>
      </nav>
    </header>

    <main class="shell">
      <div class="flash-container">
        <% if !yield(:title).to_s.downcase.match?(/\A(log)\z/) %>
          <% flash.each do |type, message| %>
            <div class="flash <%= type %>"><%= message %></div>
          <% end %>
        <% end %>
      </div>
      <%= yield %>
    </main>

    <footer>
      <p>&copy; 2026 PaperMaker. Built with passion for the scientific community. Contact: <a href="mailto:alan.turing@papermaker.local">Prof. Alan Turing (alan.turing@papermaker.local)</a></p>
    </footer>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const flashes = document.querySelectorAll('.flash');
        flashes.forEach(flash => {
          setTimeout(() => {
            flash.style.opacity = '0';
            setTimeout(() => flash.remove(), 500);
          }, 4000); // Wait 4 seconds before fading out
        });
      });
    </script>
  </body>
</html>

